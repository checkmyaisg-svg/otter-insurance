# ------------------------------------------------------------------------
# Supabase — PUBLIC (safe for the browser bundle)
# ------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ------------------------------------------------------------------------
# Supabase — SERVER ONLY (never exposed to the client)
# Used by the send job and webhook. Bypasses RLS.
# ------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------------------
# WhatsApp Cloud API — SERVER ONLY
# ------------------------------------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ------------------------------------------------------------------------
# Send job — SERVER ONLY
# Bearer token n8n / Vercel Cron presents to /api/jobs/send-due-messages
# ------------------------------------------------------------------------
JOB_SECRET=
